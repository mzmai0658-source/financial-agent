# Copy these values into your local environment before running the pipeline.

# DeepSeek / OpenAI-compatible chat API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=120
DEEPSEEK_MAX_RETRIES=5

# DashScope embedding API
DASHSCOPE_API_KEY=
DASHSCOPE_MAX_RETRIES=3
DASHSCOPE_RETRY_BACKOFF_SECONDS=1.5

# PaddleOCR async API, only needed when converting PDFs to OCR JSON
PADDLEOCR_API_TOKEN=
OCR_API_TOKEN=

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=financial_report
DB_CHARSET=utf8mb4
